@model CreateScheduleViewModel
@{
    ViewData["Title"] = "Create Schedule";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="fw-bold mb-0">Create Schedule</h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-3">
        <i class="bi bi-arrow-left me-1"></i> Back
    </a>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger py-2 small" asp-validation-summary="All"></div>
}

<form asp-action="Create" method="post" id="createScheduleForm">
    <div class="row g-3 mb-4">
        <div class="col-auto">
            <label asp-for="WeekNumber" class="form-label small text-muted">Week</label>
            <input asp-for="WeekNumber" class="form-control form-control-sm" style="width: 100px" type="number" min="1" max="53" />
            <span asp-validation-for="WeekNumber" class="text-danger small"></span>
        </div>
        <div class="col-auto">
            <label asp-for="Year" class="form-label small text-muted">Year</label>
            <input asp-for="Year" class="form-control form-control-sm" style="width: 120px" type="number" />
            <span asp-validation-for="Year" class="text-danger small"></span>
        </div>
    </div>

    <div class="text-center py-5 text-muted" id="shiftPlaceholder">
        <i class="bi bi-plus-circle fs-2 d-block mb-2"></i>
        <p class="mb-0">Set the week and year above, then save.</p>
        <p class="small">You can add shifts on the edit page afterwards.</p>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-3 px-4">Cancel</a>
        <button type="submit" class="btn btn-dark btn-sm rounded-3 px-4">
            <i class="bi bi-plus-lg me-1"></i> Create Schedule
        </button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
